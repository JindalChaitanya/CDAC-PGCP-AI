   "cell_type": "markdown",
   "id": "5a543799",
   "metadata": {},
   "source": [
    "#### 95% Confidence Interval for Age"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "17a6fccb",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Sample size: 714\n",
      "Mean Age: 29.70\n",
      "95% CI using analytical method: (28.63, 30.77)\n"
     ]
    }
   ],
   "source": [
    "n = len(age_data)\n",
    "alpha = 0.05\n",
    "\n",
    "mean_age = age_data.mean()\n",
    "sem_age = stats.sem(age_data)\n",
    "\n",
    "t_value = stats.t.ppf(1 - alpha/2, df=n-1)\n",
    "\n",
    "margin_error = t_value * sem_age\n",
    "ci_lower = mean_age - margin_error\n",
    "ci_upper = mean_age + margin_error\n",
    "\n",
    "print(f\"Sample size: {n}\")\n",
    "print(f\"Mean Age: {mean_age:.2f}\")\n",
    "print(f\"95% CI using analytical method: ({ci_lower:.2f}, {ci_upper:.2f})\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "d6ad89ec",
   "metadata": {},
   "source": [
    "#### 95% Confidence Interval by Sampling"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 20,
   "id": "da1c3f45",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "95% CI using bootstrap: (28.66, 30.78)\n"
     ]
    }
   ],
   "source": [
    "np.random.seed(42)\n",
    "\n",
    "bootstrap_means = []\n",
    "B = 10000\n",
    "\n",
    "for _ in range(B):\n",
    "    sample = np.random.choice(age_data, size=len(age_data), replace=True)\n",
    "    bootstrap_means.append(np.mean(sample))\n",
    "\n",
    "bootstrap_means = np.array(bootstrap_means)\n",
    "\n",
    "boot_lower = np.percentile(bootstrap_means, 2.5)\n",
    "boot_upper = np.percentile(bootstrap_means, 97.5)\n",
    "\n",
    "print(f\"95% CI using bootstrap: ({boot_lower:.2f}, {boot_upper:.2f})\")"
   ]
  },
